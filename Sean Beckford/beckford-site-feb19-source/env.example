# Sanity CMS Configuration
# Get these from: https://www.sanity.io/manage
NEXT_PUBLIC_SANITY_PROJECT_ID=your-project-id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# Optional: For server-side data fetching (keep secret!)
SANITY_API_TOKEN=your-api-token

# Stripe (payments) - add to Vercel env vars for production
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...

# Keystatic (GitHub storage — matches KEYSTATIC_GITHUB_* on Vercel)
# OAuth app callback must be: https://www.beckfordmoves.com/api/keystatic/github/oauth/callback
# (add the apex host variant if you serve without www)
KEYSTATIC_SECRET=
KEYSTATIC_GITHUB_CLIENT_ID=
KEYSTATIC_GITHUB_CLIENT_SECRET=
# Optional: defaults to ackersml/beckford-moves
# KEYSTATIC_GITHUB_REPO=ackersml/beckford-moves
# Local editing only: reads/writes homepage/ and about/ YAML on disk, no GitHub login
# KEYSTATIC_LOCAL=true
