# =============================================================================
# Copy to .env.local for local development. Do not commit .env or .env.local.
# Set the same variables in Vercel → Project → Settings → Environment Variables.
# =============================================================================

# --- Keystatic (GitHub storage) — required on Vercel for /keystatic
# OAuth app callback URLs (add all in GitHub → Developer settings → OAuth Apps):
#   https://www.beckfordmoves.com/api/keystatic/github/oauth/callback
#   https://beckfordmoves.com/api/keystatic/github/oauth/callback
#   http://localhost:3000/api/keystatic/github/oauth/callback (local dev)
KEYSTATIC_SECRET=
KEYSTATIC_GITHUB_CLIENT_ID=
KEYSTATIC_GITHUB_CLIENT_SECRET=
# Optional; defaults to ackersml/beckford-moves in keystatic.config.ts
# KEYSTATIC_GITHUB_REPO=ackersml/beckford-moves
# Local only: YAML on disk, no GitHub login (do not set on Vercel)
# KEYSTATIC_LOCAL=true

# --- Sanity CMS (if used)
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01
SANITY_API_TOKEN=

# --- Stripe (if used)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
